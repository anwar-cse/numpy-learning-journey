   "source": [
    "import numpy as np\n",
    "\n",
    "arr1=np.array([1,3,4,2,5,6])\n",
    "print(arr1[2])\n",
    "\n",
    "arr2=np.array([[2,3,4,5,7,8],[2,3,4,5,6,8]])\n",
    "print(arr2[1][1])\n",
    "\n",
    "#short way\n",
    "print(arr2[1,2])"
   ]
  },
